# Portal go!PAN
PAN_LOGIN_URL=https://veiculos.bancopan.com.br/login
PAN_USERNAME=
PAN_PASSWORD=

# Callback pro Lovable (o worker NÃO fala com o Supabase direto —
# o Lovable Cloud não expõe a service_role key pra fora).
# LOVABLE_CALLBACK_URL é o endpoint que o Lovable vai criar, algo tipo
# https://seu-projeto.lovable.app/api/pan-callback
LOVABLE_CALLBACK_URL=

# Segredo compartilhado — usado nos DOIS sentidos:
# 1) Lovable manda esse Bearer token quando chama o worker (POST /consulta-cpf)
# 2) O worker manda esse Bearer token quando chama o LOVABLE_CALLBACK_URL de volta
WORKER_SECRET=

# Opcional
PORT=3000
RESULT_TIMEOUT_MS=30000
MIN_INTERVALO_MS=3000
MAX_INTERVALO_MS=8000
